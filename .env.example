# =============================================================================
# OpsBot Configuration
# Copy to .env and fill in your values
# =============================================================================

# --- LLM ---
LITELLM_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
# For AWS Bedrock: set AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION
# For Ollama: OLLAMA_BASE_URL=http://localhost:11434

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-
SLACK_APP_TOKEN=xapp-          # socket mode
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=#ops-bot  # where to post unsolicited notifications

# --- Database ---
DATABASE_URL=postgresql+asyncpg://opsbot:opsbot@localhost:5432/opsbot
DATABASE_URL_SYNC=postgresql://opsbot:opsbot@localhost:5432/opsbot

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- GitHub ---
GITHUB_TOKEN=ghp_
GITHUB_ORG=                     # default org for GitHub operations

# --- Kubernetes ---
# Leave empty to use in-cluster config (when running in k8s)
# Or set to path of kubeconfig file
KUBECONFIG_PATH=~/.kube/config
K8S_DEFAULT_NAMESPACE=default

# --- ArgoCD ---
ARGOCD_SERVER_URL=https://argocd.example.com
ARGOCD_TOKEN=
ARGOCD_INSECURE=false

# --- Terraform ---
TERRAFORM_WORKING_DIR=/tmp/terraform
TFE_TOKEN=                      # Terraform Cloud token (optional)

# --- AWS ---
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Or use IAM roles (recommended in production)

# --- GCP ---
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCP_PROJECT=

# --- Azure ---
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Observability ---
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001
GRAFANA_TOKEN=

DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

PAGERDUTY_API_KEY=
PAGERDUTY_FROM_EMAIL=

OPSGENIE_API_KEY=

# --- Bitbucket ---
# Cloud:  BITBUCKET_URL=https://api.bitbucket.org/2.0 (default)
# Server: BITBUCKET_URL=https://bitbucket.yourcompany.com
BITBUCKET_URL=https://api.bitbucket.org/2.0
BITBUCKET_WORKSPACE=                 # default workspace / project key
# Cloud auth: username + App Password (create at bitbucket.org → Personal Settings → App passwords)
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
# Server auth: use a Personal Access Token instead
# BITBUCKET_TOKEN=

# --- GitLab ---
# Cloud: GITLAB_URL=https://gitlab.com (default)
# Self-hosted: GITLAB_URL=https://gitlab.yourcompany.com
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=                        # Personal Access Token (scope: api)
GITLAB_DEFAULT_GROUP=                # default group/namespace for project listing

# --- Jira ---
# Cloud:  JIRA_URL=https://yoursite.atlassian.net
# Server: JIRA_URL=https://jira.yourcompany.com
JIRA_URL=
# Cloud auth: email + API token (create at id.atlassian.com → Security → API tokens)
# Server auth: username + password or Personal Access Token
JIRA_USERNAME=                       # email for Cloud, username for Server
JIRA_API_TOKEN=                      # API token for Cloud, password/PAT for Server
JIRA_DEFAULT_PROJECT=                # default project key (e.g. OPS, SRE, INFRA)

# --- Confluence ---
# Cloud:  CONFLUENCE_URL=https://yoursite.atlassian.net/wiki
# Server: CONFLUENCE_URL=https://confluence.yourcompany.com
CONFLUENCE_URL=
CONFLUENCE_USERNAME=                 # same as JIRA_USERNAME for Atlassian Cloud
CONFLUENCE_API_TOKEN=                # same as JIRA_API_TOKEN for Atlassian Cloud
CONFLUENCE_DEFAULT_SPACE=            # default space key (e.g. SRE, OPS, RUNBOOKS)

# --- OpenSearch / Elasticsearch ---
# Supports both OpenSearch and Elasticsearch (identical REST API)
OPENSEARCH_URL=http://localhost:9200
# Basic auth (choose one: basic auth OR API key)
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
# API key auth (for Elastic Cloud or OpenSearch Serverless)
OPENSEARCH_API_KEY=
# Default index pattern for log queries (adjust to match your setup)
# Common patterns: logs-*, filebeat-*, logstash-*, fluentd-*, k8s-*
OPENSEARCH_DEFAULT_INDEX=logs-*
OPENSEARCH_VERIFY_SSL=true

# --- RBAC ---
# Comma-separated Slack user IDs who can approve DESTRUCTIVE operations
DEFAULT_APPROVER_SLACK_IDS=
# Role: admin, sre, developer, readonly
DEFAULT_USER_ROLE=developer

# --- Security ---
SECRET_KEY=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- App ---
APP_NAME=OpsBot
APP_ENV=development             # development | staging | production
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- MCP Servers ---
# These are automatically managed; override commands here if needed
MCP_KUBERNETES_COMMAND=npx -y kubernetes-mcp-server@latest
MCP_GITHUB_COMMAND=npx -y @modelcontextprotocol/server-github
MCP_TERRAFORM_COMMAND=docker run --rm -i hashicorp/terraform-mcp-server:0.4.0
MCP_ARGOCD_COMMAND=node /app/mcp-servers/argocd-mcp/dist/index.js
MCP_PROMETHEUS_COMMAND=node /app/mcp-servers/prometheus-mcp/dist/index.js
MCP_DATADOG_COMMAND=node /app/mcp-servers/datadog-mcp/dist/index.js
MCP_OPENSEARCH_COMMAND=node /app/mcp-servers/opensearch-mcp/dist/index.js
MCP_BITBUCKET_COMMAND=node /app/mcp-servers/bitbucket-mcp/dist/index.js
MCP_GITLAB_COMMAND=node /app/mcp-servers/gitlab-mcp/dist/index.js
MCP_JIRA_COMMAND=node /app/mcp-servers/jira-mcp/dist/index.js
MCP_CONFLUENCE_COMMAND=node /app/mcp-servers/confluence-mcp/dist/index.js

# --- Approval Settings ---
APPROVAL_TIMEOUT_MINUTES=30    # auto-deny after this many minutes
REQUIRE_DUAL_APPROVAL_FOR=delete_namespace,drop_database
